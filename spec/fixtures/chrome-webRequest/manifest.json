{
  "name": "chrome-webRequest",
  "version": "1.0",
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_end"
    }
  ],
  "manifest_version": 3,
  "permissions": ["webRequest", "webRequestBlocking", "<all_urls>"]
}
